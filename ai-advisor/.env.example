# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-openai-key

# Database — use the EXACT connection string from Supabase "Connect" button
# Note: psycopg driver prefix (postgresql+psycopg://), unlike the Next.js app
DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:54322/postgres

# Flask
FLASK_ENV=development
FLASK_DEBUG=True

# Supabase (for client operations)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Optional: set to 'true' to read from local JSON files in data/ instead of the DB
USE_JSON_FALLBACK=false
