# Supabase (get these from `npx supabase start` output, or Supabase dashboard for prod)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SECRET_KEY=your-secret-key

# Postgres (local Supabase defaults shown; use pooled connection string in prod)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
DIRECT_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres


# Shared secret for /api/cron/* routes
CRON_SECRET=any-random-string-you-want
